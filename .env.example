# Copy this file to .env. The defaults are safe for local smoke tests only.
DOCKET_ENVIRONMENT=smoke
DOCKET_DATABASE_URL=postgresql+psycopg://docket:docket-smoke@postgres:5432/docket
DOCKET_TIMEZONE=America/Los_Angeles
DOCKET_EXTERNAL_CALLS_ENABLED=false
DOCKET_AUTO_CREATE_SCHEMA=false
DOCKET_LOG_LEVEL=INFO
DOCKET_OPERATION_POLL_SECONDS=5
DOCKET_RECONCILIATION_POLL_SECONDS=300
DOCKET_STALE_LEASE_POLL_SECONDS=60
DOCKET_CREDENTIALS_DIR=./secrets/smoke
DOCKET_UID=10001
DOCKET_GID=10001
POSTGRES_PASSWORD=docket-smoke

# Private SearXNG service. It is reachable from this Compose network only.
SEARXNG_IMAGE=docker.io/searxng/searxng:2026.7.19-6da6eee26@sha256:b8ca38ba06eea544d7555e88321e212ddc0d5c3c7de055419cfb2e5c6bf30812

# Replace these before enabling the Hermes profile.
DOCKET_OPERATOR_DISCORD_USER_ID=000000000000000001
DOCKET_DISCORD_GUILD_ID=000000000000000002
DOCKET_CHAT_CHANNEL_ID=000000000000000003
DOCKET_QUEUE_CHANNEL_ID=000000000000000004
DOCKET_SYSTEM_CHANNEL_ID=000000000000000005

DOCKET_TO_HERMES_TOKEN_FILE=/run/docket-secrets/docket_to_hermes_token
HERMES_TO_DOCKET_TOKEN_FILE=/run/docket-secrets/hermes_to_docket_token
DOCKET_DISCORD_PROJECTION_ENABLED=true
DOCKET_DISCORD_PROJECTION_URL=http://hermes:8787
DOCKET_DISCORD_PROJECTION_POLL_SECONDS=5
DOCKET_DISCORD_PROJECTION_LEASE_SECONDS=30
DOCKET_DISCORD_PROJECTION_MAX_ATTEMPTS=10
DOCKET_APPROVAL_TTL_SECONDS=86400
DOCKET_LOCAL_ACTION_TTL_SECONDS=86400
DOCKET_DAILY_ROLLOVER_POLL_SECONDS=60
DOCKET_DAILY_ROLLOVER_HOUR=7
DOCKET_INTERACTION_SIGNING_KEY_FILE=/run/docket-secrets/interaction_signing_key
GOOGLE_OAUTH_CLIENT_FILE=/run/docket-secrets/google_oauth_client.json
# Generated by scripts/setup-google-oauth.sh; do not hand-author this file.
GOOGLE_OAUTH_TOKEN_FILE=/run/docket-secrets/google_oauth_token.json
GOOGLE_CALENDAR_ID=docket-smoke-calendar
GOOGLE_ACCOUNT_EXTERNAL_ID=primary

# Hermes release pinned by tag, image digest, and OCI revision label.
HERMES_IMAGE=nousresearch/hermes-agent:v2026.7.20@sha256:f7b35053268f532f98955195c909f15a230470fbcbdacaa9fdecb95707dad04a
HERMES_SOURCE_COMMIT=3ef6bbd201263d354fd83ec55b3c306ded2eb72a
HERMES_UID=1000
HERMES_GID=1000
